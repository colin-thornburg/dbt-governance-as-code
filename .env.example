# dbt Cloud API (required for Cloud mode)
# Generate a service token with "Metadata Only" permissions in dbt Cloud:
# Account Settings → Service Tokens → New Token → Metadata Only
DBT_CLOUD_API_TOKEN=

# For AI semantic review (optional — deterministic rules work without it)
ANTHROPIC_API_KEY=

# For GitHub PR annotations (optional)
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_SHA=

# For GitLab MR notes (optional)
GITLAB_TOKEN=
GITLAB_PROJECT_ID=
CI_MERGE_REQUEST_IID=
